# Lobster - Personal AI Assistant Configuration
# Copy this to .env and fill in your values

# LLM Configuration
# For local (Ollama) - leave API_KEY empty
LLM_PROVIDER=ollama
LLM_MODEL=gemma4
OLLAMA_BASE_URL=http://localhost:11434

# For OpenAI (optional - only if you want cloud fallback)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Chat Integrations
# Telegram: message @BotFather on Telegram to create a bot
TELEGRAM_BOT_TOKEN=

# WhatsApp: uses whatsapp-web.js, no tokens needed (QR code login)
# Just set ENABLE_WHATSAPP=true and scan the QR code on startup
ENABLE_WHATSAPP=false

# Server
PORT=3000
HOST=0.0.0.0
